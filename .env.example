# OpenAI (for cloud deployment - AI recommendations & embeddings)
OPENAI_API_KEY=sk-your_key_here

# Browserbase (optional - falls back to local Playwright if not set)
BROWSERBASE_API_KEY=your_api_key_here
BROWSERBASE_PROJECT_ID=your_project_id_here

# Ollama (local only)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Mock scraping (use sample data, no browser)
# MOCK_SCRAPING=1
